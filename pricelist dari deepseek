<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>RatuAyu by Fairuzqa - Pricelist 2026</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Inter', system-ui, -apple-system, 'Roboto', sans-serif;
            background: #fefaf5;
            color: #2c2418;
            padding: 20px;
            line-height: 1.5;
        }

        .container {
            max-width: 1300px;
            margin: 0 auto;
            background: white;
            border-radius: 32px;
            box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            padding: 28px 24px 40px;
        }

        h1 {
            font-size: 1.9rem;
            text-align: center;
            font-weight: 600;
            letter-spacing: -0.3px;
            background: linear-gradient(135deg, #b47c4a, #9b5e2c);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 8px;
        }

        .sub {
            text-align: center;
            color: #7f6b55;
            margin-bottom: 32px;
            font-size: 0.95rem;
            border-bottom: 1px solid #f0e4d6;
            padding-bottom: 16px;
        }

        /* category grid */
        .category-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .category-card {
            background: #fff7f0;
            border-radius: 28px;
            padding: 24px 20px;
            cursor: pointer;
            transition: all 0.25s ease;
            border: 1px solid #f5e4d4;
            box-shadow: 0 5px 12px rgba(0,0,0,0.02);
            text-align: center;
        }

        .category-card:hover {
            transform: translateY(-5px);
            border-color: #dbbd9b;
            background: #fffaf3;
            box-shadow: 0 20px 25px -12px rgba(156, 100, 45, 0.15);
        }

        .category-icon {
            font-size: 2.8rem;
            margin-bottom: 12px;
        }

        .category-card h3 {
            font-size: 1.5rem;
            font-weight: 600;
            color: #6b3f1c;
            margin-bottom: 8px;
        }

        .category-card p {
            color: #8f6b44;
            font-size: 0.85rem;
        }

        /* content area */
        .content-wrapper {
            animation: fadeIn 0.25s ease;
        }

        .back-btn {
            background: none;
            border: none;
            font-size: 1rem;
            font-weight: 500;
            color: #b47c4a;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 28px;
            padding: 8px 12px;
            border-radius: 60px;
            transition: background 0.2s;
        }

        .back-btn:hover {
            background: #fef0e4;
        }

        .package-section {
            margin-bottom: 32px;
            border-bottom: 1px dashed #efdecb;
            padding-bottom: 24px;
        }

        .package-title {
            font-size: 1.7rem;
            font-weight: 700;
            color: #4f2e12;
            margin-bottom: 12px;
            border-left: 6px solid #e7b87b;
            padding-left: 16px;
        }

        .price {
            font-size: 1.35rem;
            font-weight: 700;
            color: #c1813b;
            margin: 10px 0 8px;
        }

        .package-desc {
            background: #fef9f2;
            padding: 16px 20px;
            border-radius: 24px;
            margin: 12px 0;
        }

        .package-desc ul, .note-list {
            margin: 12px 0 8px 20px;
        }

        .package-desc li {
            margin: 6px 0;
        }

        .badge {
            background: #e9dfd3;
            color: #664d31;
            display: inline-block;
            padding: 4px 12px;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 500;
            margin-right: 10px;
        }

        .terms {
            background: #f3ede7;
            border-radius: 24px;
            padding: 20px;
            margin-top: 28px;
            font-size: 0.85rem;
        }

        .terms h4 {
            font-size: 1.2rem;
            margin-bottom: 12px;
            color: #533e26;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        hr {
            margin: 20px 0;
            border: none;
            border-top: 1px solid #f0e0d0;
        }

        .grid-2col {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        .note-warning {
            background: #fff0e0;
            padding: 12px 18px;
            border-radius: 18px;
            font-size: 0.85rem;
            color: #a5562c;
            margin-top: 16px;
        }

        footer {
            text-align: center;
            margin-top: 40px;
            font-size: 0.75rem;
            color: #b9a48c;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px);}
            to { opacity: 1; transform: translateY(0);}
        }

        @media (max-width: 700px) {
            .container {
                padding: 20px 16px;
            }
            .package-title {
                font-size: 1.4rem;
            }
        }
    </style>
</head>
