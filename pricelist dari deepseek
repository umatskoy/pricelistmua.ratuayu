    // --------------------------------------------------------------
    // ROUTING / UI SWITCH
    // --------------------------------------------------------------
    const categoryView = document.getElementById('categoryView');
    const detailView = document.getElementById('detailView');
    let currentRendered = null;

    function showCategory() {
        categoryView.style.display = 'block';
        detailView.style.display = 'none';
        detailView.innerHTML = '';
        currentRendered = null;
    }

    function showDetail(renderFunc) {
        const contentHtml = renderFunc();
        detailView.innerHTML = contentHtml;
        categoryView.style.display = 'none';
        detailView.style.display = 'block';
        // attach back event listener after insert
        const backBtn = document.getElementById('backToCategory');
        if (backBtn) {
            backBtn.addEventListener('click', showCategory);
        }
        currentRendered = renderFunc;
    }

    // Event listener untuk card kategori
    document.querySelectorAll('.category-card').forEach(card => {
        card.addEventListener('click', (e) => {
            const cat = card.getAttribute('data-cat');
            if (cat === 'wedding') showDetail(renderWedding);
            else if (cat === 'regulerOwner') showDetail(renderRegulerOwner);
            else if (cat === 'regulerTeam') showDetail(renderRegulerTeam);
            else if (cat === 'engagement') showDetail(renderEngagement);
        });
    });

    // initial state
    showCategory();
</script>
</body>
</html>
