    // --------------------------------------------------------------
    // RENDER HELPER
    // --------------------------------------------------------------
    function renderWedding() {
        let html = `<div class="content-wrapper">
            <button class="back-btn" id="backToCategory">← Kembali ke kategori</button>
            <div class="package-title">${dataWedding.title}</div>`;

        for (let pkg of dataWedding.packages) {
            html += `<div class="package-section">
                        <div style="display:flex; align-items: baseline; flex-wrap:wrap; gap:8px;">
                            <h3 style="font-size:1.45rem; font-weight:700; color:#543a22;">${pkg.name}</h3>
                            ${pkg.price ? `<span class="price">${pkg.price}</span>` : ''}
                        </div>
                        <div class="package-desc">
                            <p><strong>${pkg.desc || ''}</strong></p>
                            <ul>`;
            if (pkg.details) {
                pkg.details.forEach(d => { html += `<li>${d}</li>`; });
            }
            if (pkg.items) {
                html += `<li style="list-style: none; margin-top: 8px;"><strong>💠 Paket Adat :</strong></li>`;
                pkg.items.forEach(item => { html += `<li>• ${item}</li>`; });
            }
            html += `</ul>`;
            if (pkg.priceNote) html += `<div class="note-warning">📌 ${pkg.priceNote}</div>`;
            if (pkg.note) html += `<div class="note-warning">✨ ${pkg.note}</div>`;
            html += `</div></div>`;
        }

        html += `<div class="terms"><h4>📋 Ketentuan Wedding Package</h4><ul>`;
        dataWedding.globalNotes.forEach(n => { html += `<li>${n}</li>`; });
        html += `</ul><p class="note-warning" style="margin-top:12px">⭐ Untuk Silver & Gold (tanpa attire): detail lengkap hubungi admin. ⭐ Traditional wedding adalah biaya tambahan (belum termasuk makeup & busana utama).</p></div>`;
        html += `</div>`;
        return html;
    }

